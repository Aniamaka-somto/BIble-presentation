{
  "name": "scripture-caster",
  "version": "0.1.0",
  "description": "Live AI scripture detection and presentation for church services",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.scripturecaster.app",
    "productName": "Scripture Caster",
    "directories": { "output": "release" },
    "files": ["out/**/*"],
    "win": { "target": "nsis" },
    "linux": { "target": ["AppImage"] }
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "better-sqlite3": "^11.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-vite": "^2.3.0",
    "electron-builder": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "prisma": "^5.20.0"
  }
}
